    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>ElBruno.NetAgent</AssemblyName>
    <RootNamespace>ElBruno.NetAgent</RootNamespace>
    <Version>0.1.0</Version>
